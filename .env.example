# ─────────────────────────────────────────────────────────────────────────────
# LectMent — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── IBM watsonx.ai ────────────────────────────────────────────────────────────
# Dashboard: https://dataplatform.cloud.ibm.com/  → Your project → Manage → Access
WATSONX_API_KEY=
WATSONX_URL=
WATSONX_PROJECT_ID=
# Override the default Granite model (optional — leave blank for ibm/granite-13b-chat-v2)
WATSONX_MODEL_ID=ibm/granite-13b-chat-v2

# ── IBM watsonx Orchestrate ───────────────────────────────────────────────────
# Dashboard: https://www.ibm.com/products/watsonx-orchestrate  → Settings → API
# Used to invoke Orchestrate skill flows (optional — leave blank to skip)
ORCHESTRATE_API_KEY=
ORCHESTRATE_INSTANCE_URL=
#ORCHESTRATE_SKILL_FLOW_ID=your_skill_flow_id_here

# ── IBM Watson Speech-to-Text (OPTIONAL) ──────────────────────────────────────
# Leave blank to fall back to local Whisper transcription
# Dashboard: https://cloud.ibm.com/ → Speech to Text service → Credentials
IBM_STT_API_KEY=
IBM_STT_URL=
